@{
    ViewData["Title"] = "Fleet Control";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600&family=IBM+Plex+Sans:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<head>
    <link rel="stylesheet" href="~/css/Home.css" asp-append-version="true" />

</head>

<div class="hero-wrap">
    <div class="eyebrow mt-3">IOT Asset Operations</div>

    <div class="hero-grid">
        <div>
            <h1>Asset control</h1>
            <p>Manage your device hierarchy, firmware rollouts, and asset groupings from one place.</p>
        </div>
        <svg class="tree-svg" viewBox="0 0 220 140" width="100%" height="140" role="img" aria-label="Diagram of a device group hierarchy">
            <g class="link" stroke-width="1.5" fill="none">
                <line x1="110" y1="26" x2="60" y2="72"></line>
                <line x1="110" y1="26" x2="160" y2="72"></line>
                <line x1="60" y1="72" x2="30" y2="118"></line>
                <line x1="60" y1="72" x2="90" y2="118"></line>
            </g>
            <circle class="node root" cx="110" cy="26" r="7"></circle>
            <circle class="node" cx="60" cy="72" r="5.5"></circle>
            <circle class="node" cx="160" cy="72" r="5.5"></circle>
            <circle class="node" cx="30" cy="118" r="4.5"></circle>
            <circle class="node" cx="90" cy="118" r="4.5"></circle>
        </svg>
    </div>

    <div class="stat-row">
        <div class="stat"><strong>@(ViewBag.GroupCount ?? "—")</strong><span>Groups</span></div>
        <div class="stat"><strong>@(ViewBag.FirmwareCount ?? "—")</strong><span>Firmware versions</span></div>
        <div class="stat"><strong>@(ViewBag.DeviceCount ?? "—")</strong><span>Devices tracked</span></div>
    </div>

    <div class="panels">
        <a class="panel" asp-controller="Groups" asp-action="Index">
            <span class="icon-badge">
                <svg width="20" height="20" viewBox="0 0 22 22" fill="none" stroke="#B5461F" stroke-width="1.6" stroke-linecap="round">
                    <circle cx="11" cy="4" r="2"></circle>
                    <circle cx="5" cy="18" r="2"></circle>
                    <circle cx="17" cy="18" r="2"></circle>
                    <path d="M11 6 L11 11 M11 11 L5 16 M11 11 L17 16"></path>
                </svg>
            </span>
            <h2>Groups</h2>
            <p>Organise devices into nested groups, from fleet-wide down to a single depot.</p>
            <span class="go">MANAGE GROUPS →</span>
        </a>
        <a class="panel" asp-controller="Firmware" asp-action="Index">
            <span class="icon-badge">
                <svg width="20" height="20" viewBox="0 0 22 22" fill="none" stroke="#B5461F" stroke-width="1.6" stroke-linejoin="round">
                    <path d="M11 3 L20 8 L11 13 L2 8 Z"></path>
                    <path d="M2 13 L11 18 L20 13" stroke-linecap="round"></path>
                </svg>
            </span>
            <h2>Firmware</h2>
            <p>Track firmware releases and see which version each device is running.</p>
            <span class="go">MANAGE FIRMWARE →</span>
        </a>
        <a class="panel" asp-controller="Devices" asp-action="Index">
            <span class="icon-badge">
                <svg width="20" height="20" viewBox="0 0 22 22" fill="none" stroke="#B5461F" stroke-width="1.6" stroke-linecap="round">
                    <circle cx="11" cy="14" r="2.2" fill="#B5461F" stroke="none"></circle>
                    <path d="M6 11a7 7 0 0 1 10 0"></path>
                    <path d="M3.5 8a11 11 0 0 1 15 0"></path>
                </svg>
            </span>
            <h2>Devices</h2>
            <p>View and assign every tracked device to a group and firmware version.</p>
            <span class="go">MANAGE DEVICES →</span>
        </a>
    </div>
</div>