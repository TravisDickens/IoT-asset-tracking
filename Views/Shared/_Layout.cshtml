<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IOT Management Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500&family=Space+Grotesk:wght@500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/IOTAssetTracking.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="am-header">
        <nav class="am-nav navbar navbar-expand-sm">
            <div class="am-nav__inner">
                <a class="am-nav__brand" asp-area="" asp-controller="Home" asp-action="Index">
                    Asset Management
                </a>
                <button class="am-nav__toggler navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#amNav"
                        aria-controls="amNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse am-nav__collapse" id="amNav">
                    <ul class="am-nav__list navbar-nav">
                        <li class="nav-item">
                            <a class="am-nav__link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="am-nav__link" asp-controller="Groups" asp-action="Index">Groups</a>
                        </li>
                        <li class="nav-item">
                            <a class="am-nav__link" asp-controller="Firmware" asp-action="Index">Firmware</a>
                        </li>
                        <li class="nav-item">
                            <a class="am-nav__link" asp-controller="Devices" asp-action="Index">Devices</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>